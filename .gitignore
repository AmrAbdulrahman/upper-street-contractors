# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/apps/website/.next/
/apps/cms/.next/
/out/
/apps/website/out/

# production
/build
/dist

# misc
.DS_Store
*.pem
.nx/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.envrc
!apps/website/.envrc

# graphql codegen output
apps/website/src/generated/*
!apps/website/src/generated/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
apps/website/next-env.d.ts
apps/cms/next-env.d.ts

# puppeteer
.puppeteer-cache/

vitest.config.*.timestamp*

.zero-cms-store/generated
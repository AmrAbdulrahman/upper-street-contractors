# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/apps/website/.next/
/out/
/apps/website/out/

# production
/build

# misc
.DS_Store
*.pem
.nx/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.envrc
!apps/website/.envrc

# graphql codegen output
apps/website/src/generated/*
!apps/website/src/generated/.gitkeep

# vercel
.vercel

# hugerte editor skins (copied from node_modules by scripts/copy-hugerte-skins.mjs)
/apps/website/public/hugerte/

# typescript
*.tsbuildinfo
next-env.d.ts
apps/website/next-env.d.ts

# puppeteer
.puppeteer-cache/

# strapi (apps/cms)
apps/cms/.cache/
apps/cms/.tmp/
apps/cms/build/
apps/cms/dist/
apps/cms/.strapi/
apps/cms/.strapi-updater.json
apps/cms/.strapi-cloud.json
apps/cms/.local-api-token
apps/cms/public/uploads/*
!apps/cms/public/uploads/.gitkeep
# Local development
STRAPI_CLOUD_URL=https://your-project.strapiapp.com
STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Public website origin — used by Strapi CORS for client-side cold-start health checks
# WEBSITE_URL=https://upperstreet.contractors

# READ-ONLY API token from Strapi admin: Settings → API Tokens.
# Server-side only (never exposed to the browser). Used for anonymous published
# reads on production + build scripts. Editors' own JWTs (via login) authorize
# all writes/publishes on staging, so this token must NOT be full-access.
STRAPI_API_TOKEN=

# Optional: cloud token for build scripts when local CMS is not running
# STRAPI_CLOUD_API_TOKEN=

ENABLE_PREVIEW=false

# Cache revalidation secret — must match REVALIDATE_SECRET on the deployed site.
# Set this to a random string (e.g. openssl rand -hex 32).
# Used by POST /api/revalidate and Strapi Cloud webhook header x-revalidate-secret.
# REVALIDATE_SECRET=

# Override dev→Cloud guard (default: off). Never set to true in staging/prod.
# ALLOW_REMOTE_CMS_IN_DEV=true

# Always-on inspect overlays (otherwise use ?inspect=true when ENABLE_PREVIEW=true)
# NEXT_PUBLIC_STRAPI_INSPECTION_MODE=true

# Cloud (Strapi Cloud app URL — no /admin suffix)
# STRAPI_CLOUD_URL=https://your-project.strapiapp.com
# STRAPI_URL=https://your-project.strapiapp.com
# NEXT_PUBLIC_STRAPI_URL=https://your-project.strapiapp.com
# STRAPI_API_TOKEN=
# STRAPI_TRANSFER_TOKEN=
# ENABLE_PREVIEW=true

# --- zero-cms auth (cms-app) ---
# Secret for signing session tokens. Required to boot cms-app at all — it's the
# sole network-reachable writer, so auth is never optional there (unlike the old
# in-website wiring). Not needed by `website` itself.
# ZERO_CMS_AUTH_SECRET=change-me-to-a-long-random-string
# First admin, seeded into users.json on cms-app boot when the store has no users.
# Seeded with forcePasswordUpdate=true.
# ZERO_CMS_ADMIN_EMAIL=admin@example.com
# ZERO_CMS_ADMIN_PASSWORD=change-me

# --- Enquiry email (nodemailer), used by POST /api/enquiry ---
# Gmail SMTP: create an App Password (Google account → Security → 2-Step
# Verification → App passwords) and use it as SMTP_PASS (16 chars, no spaces).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# ENQUIRY_TO=info@upperstreet.contractors
# ENQUIRY_FROM=Upper Street Contractors <you@gmail.com>

# --- website -> cms-app (optional locally, required on staging) ---
# Leave ZERO_CMS_REMOTE_URL unset for the simple/default local setup: `website`
# reads zero-cms-store/ directly off local disk (no cms-app process needed). Set
# it to exercise the real two-process topology locally (matches staging) — see
# root README -> Architecture. When set, ZERO_CMS_SERVICE_EMAIL/PASSWORD must be
# a dedicated **viewer-role** account on cms-app (create it once via /admin),
# never an Editor's own login.
# ZERO_CMS_REMOTE_URL=http://localhost:3001
# ZERO_CMS_SERVICE_EMAIL=service@example.com
# ZERO_CMS_SERVICE_PASSWORD=change-me
# NEXT_PUBLIC_ZERO_CMS_URL=http://localhost:3001

# cms-app CORS allow-list (comma-separated exact origins) — only needed for
# browser calls (admin UI, Inspect overlay), not the server-to-server RPC above.
# ZERO_CMS_ALLOWED_ORIGINS=http://localhost:3000

# Auto-commit+push published changes to `main` from cms-app. Off by default —
# only turn this on in a real deployment (Railway), never locally: it pushes to
# whatever `origin` your working copy points at.
# ZERO_CMS_GIT_SYNC=false

# --- zero-cms storage (ADR 0008: Upstash Redis + Vercel Blob) ---
# From the Vercel Marketplace Upstash integration ("Storage" tab). Two Redis
# tokens by design (ADR 0009's defense-in-depth split): the read-only one is
# used for ALL page rendering (public + /admin-mirrored preview — rendering
# never writes), the read-write one only by the auth-gated RPC surface.
STORAGE_KV_REST_API_URL=
STORAGE_KV_REST_API_TOKEN=
STORAGE_KV_REST_API_READ_ONLY_TOKEN=
# From the Vercel Blob store integration — media bytes (public access).
BLOB_READ_WRITE_TOKEN=

# --- zero-cms auth ---
# Secret for signing session tokens (HS256 JWT, also verified in proxy.ts to
# gate /admin/*). Required — the app refuses to boot the RPC/auth handlers
# without it.
ZERO_CMS_AUTH_SECRET=change-me-to-a-long-random-string
# First admin, seeded on boot when the Redis `users` set is empty. Seeded with
# forcePasswordUpdate=true.
ZERO_CMS_ADMIN_EMAIL=admin@example.com
ZERO_CMS_ADMIN_PASSWORD=change-me

# --- Enquiry email (nodemailer), used by POST /api/enquiry ---
# Gmail SMTP: create an App Password (Google account → Security → 2-Step
# Verification → App passwords) and use it as SMTP_PASS (16 chars, no spaces).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# ENQUIRY_TO=info@upperstreet.contractors
# ENQUIRY_FROM=Upper Street Contractors <you@gmail.com>

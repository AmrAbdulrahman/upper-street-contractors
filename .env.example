# --- zero-cms storage (ADR 0008: Upstash Redis + Vercel Blob) ---
# From the Vercel Marketplace Upstash integration ("Storage" tab). Two Redis
# tokens by design (ADR 0009's defense-in-depth split): the read-only one is
# used for ALL page rendering (public + /admin-mirrored preview — rendering
# never writes), the read-write one only by the auth-gated RPC surface.
STORAGE_KV_REST_API_URL="https://your-store.upstash.io"
STORAGE_KV_REST_API_TOKEN="your-upstash-read-write-token"
STORAGE_KV_REST_API_READ_ONLY_TOKEN="your-upstash-read-only-token"
# The same Upstash integration also writes STORAGE_KV_URL and
# STORAGE_REDIS_URL alongside the two above — direct-protocol Redis URLs the
# app never reads (only the REST API vars are used, everywhere is edge-safe
# HTTP via @upstash/redis). Harmless to leave set; nothing to configure here.

# From the Vercel Blob store integration — media bytes (public access).
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_your-token"

# --- zero-cms auth ---
# Secret for signing session tokens (HS256 JWT, also verified in proxy.ts to
# gate /admin/*). Required — the app refuses to boot the RPC/auth handlers
# without it.
ZERO_CMS_AUTH_SECRET=your-random-32-byte-hex-secret
# Bootstrap-only: seeds the first admin when the Redis `users` set is empty
# (forcePasswordUpdate=true), then never used again — once at least one user
# exists, `seedFromEnv` is a no-op even if these stay set. Not needed on an
# already-bootstrapped environment; only required the very first time.
ZERO_CMS_ADMIN_EMAIL=admin@example.com
ZERO_CMS_ADMIN_PASSWORD=changeme

# --- Enquiry email (nodemailer), used by POST /api/enquiry ---
# Gmail SMTP: create an App Password (Google account → Security → 2-Step
# Verification → App passwords) and use it as SMTP_PASS (16 chars, no spaces).
# All-or-nothing: /api/enquiry throws a clear "SMTP is not configured" error
# at send-time if SMTP_HOST/SMTP_USER/SMTP_PASS are missing — the rest of the
# site works fine without these, only the enquiry form's email delivery does.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
# Where enquiries are delivered. Set to the gmail for now so it's testable;
# switch to info@upperstreet.contractors for production.
ENQUIRY_TO=your-email@gmail.com
ENQUIRY_FROM="Upper Street Contractors <your-email@gmail.com>"

# --- Not needed here ---
# VERCEL_URL — set automatically by Vercel on every deployment (preview and
# prod), used by the post-publish cache-warming pass (ADR 0012,
# lib/zero-cms/server.ts) to self-fetch the site's own routes. Never set this
# manually; it falls back to localhost in local dev where it's unset.

CONTENTFUL_SPACE_ID=your_space_id_here
CONTENTFUL_ENVIRONMENT=master
CONTENTFUL_ACCESS_TOKEN=your_delivery_api_token_here
CONTENTFUL_PREVIEW_TOKEN=your_preview_token_here
# Set to true to fetch draft/unpublished Contentful content
CONTENTFUL_PREVIEW=false
# Optional: always enable entry inspection overlays in the browser
# NEXT_PUBLIC_CONTENTFUL_INSPECTION_MODE=true

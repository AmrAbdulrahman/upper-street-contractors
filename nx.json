{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default",
      "!{projectRoot}/eslint.config.mjs"
    ],
    "sharedGlobals": []
  },
  "plugins": [
    {
      "plugin": "@nx/next/plugin",
      "options": {
        "startTargetName": "start",
        "buildTargetName": "build",
        "devTargetName": "dev",
        "serveStaticTargetName": "serve-static"
      }
    },
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    }
  ],
  "targetDefaults": {
    "codegen": {
      "cache": true,
      "inputs": [
        "default",
        "{projectRoot}/codegen.ts",
        "{projectRoot}/src/**/*.graphql",
        "{workspaceRoot}/scripts/fix-graphql-codegen.mjs",
        "{workspaceRoot}/scripts/wait-for-graphql-server.mjs",
        { "env": "STRAPI_URL" },
        { "env": "STRAPI_API_TOKEN" }
      ],
      "outputs": ["{projectRoot}/src/generated"],
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/wait-for-graphql-server.mjs && graphql-codegen --config {projectRoot}/codegen.ts && node scripts/fix-graphql-codegen.mjs",
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "analytics": true
}
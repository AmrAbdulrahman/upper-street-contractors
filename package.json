{
  "name": "upper-street-contractors",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  },
  "scripts": {
    "dev": "nx dev website",
    "dev:cms": "nx dev cms",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "build": "npm run generate:sitemap && nx build website",
    "start": "nx start website",
    "lint": "nx run-many --target lint",
    "codegen": "graphql-codegen --config apps/website/codegen.ts && node scripts/fix-graphql-codegen.mjs",
    "codegen:watch": "graphql-codegen --config apps/website/codegen.ts --watch",
    "cms:push": "node scripts/strapi-transfer.mjs push",
    "cms:pull": "node scripts/strapi-transfer.mjs pull",
    "sync:claude-cli": "node scripts/sync-claude-cli.mjs"
  },
  "dependencies": {
    "@apollo/client": "^4.2.0",
    "@apollo/client-integration-nextjs": "^0.14.5",
    "@strapi/blocks-react-renderer": "^1.0.2",
    "graphql": "^16.14.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/client-preset": "^6.0.0",
    "@graphql-codegen/typed-document-node": "^7.0.0",
    "@graphql-codegen/typescript": "^6.0.1",
    "@graphql-codegen/typescript-operations": "^6.0.2",
    "@graphql-codegen/typescript-react-apollo": "^4.4.2",
    "@nx/eslint": "^22.7.5",
    "@nx/js": "^22.7.5",
    "@nx/next": "^22.7.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "nx": "^22.7.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}

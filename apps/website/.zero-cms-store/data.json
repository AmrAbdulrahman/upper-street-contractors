      "cardTitle": "Owner-led, accountable delivery",
      "cardRole": "Civil Engineer & Founder",
      "cardParagraph": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Upper Street Contracts is led by a civil engineer with a background in construction management and project delivery. That experience shapes how we work: clear planning, realistic timelines, consistent site standards, and accountability throughout.",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "We're not trying to be the biggest builder in London—we focus on reliable execution, high-quality workmanship, and the kind of communication you'd expect from a professional team.",
              "type": "text"
            }
          ]
        }
      ],
      "cardBanner": "d3957164-3ac2-4267-ab6b-ae5728b85f77"
    },
    "__draft": null
  },

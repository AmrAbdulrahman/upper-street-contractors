  {
    "__id": "39ce386a-904e-4834-80b8-52e5c8d8ffd3",
    "__type": "who-we-are-section",
    "__status": "published",
    "values": {
      "overline": "who we are",
      "title": "A local team you can trust",
      "body": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "We're a family-run, owner-led team based in Islington. We specialise in bathroom renovations, kitchen installations and full home refurbishments—delivering calm, organised projects for busy homeowners who want the job done properly.",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "From the first site visit to finishing touches, we manage the programme, coordinate trades, and keep communication clear. Smaller repairs and maintenance are also available for local clients who value a reliable team.",
              "type": "text"
            }
          ]
        }
      ],
      "buttons": [
        "c6363c76-0fd6-4912-8448-d59a1fbd2de8"
      ],
      "imageContainer": "e045d151-58c5-4d15-9163-411a56c31a76"

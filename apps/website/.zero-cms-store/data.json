  {
    "__id": "cd71c0a1-cd19-41db-99ae-cacc65724e6e",
    "__type": "why-choose-us-section",
    "__status": "published",
    "values": {
      "overline": "Why choose us",
      "listOfPoints": [
        "8d6cb5c8-1bfb-4b58-a7a9-1dc586b7736e",
        "16873a6a-93f3-4704-b32e-799efdb50305",

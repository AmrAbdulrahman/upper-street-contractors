{
  "name": "website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/website/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "dependsOn": ["codegen"],
      "inputs": [
        "default",
        "^default",
        "{projectRoot}/env.mjs",
        { "externalDependencies": ["next"] },
        { "dependentTasksOutputFiles": "**/*.d.ts", "transitive": true },
        { "env": "ENABLE_PREVIEW" },
        { "env": "STRAPI_URL" },
        { "env": "NEXT_PUBLIC_STRAPI_URL" },
        { "env": "NEXT_PUBLIC_STRAPI_INSPECTION_MODE" },
        { "env": "STRAPI_API_TOKEN" }
      ]
    },
    "codegen": {}
  }
}

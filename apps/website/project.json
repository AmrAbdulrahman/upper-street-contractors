{
  "name": "website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/website/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "wait-for-cms": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/wait-for-cms-before-build.mjs",
        "cwd": "{workspaceRoot}"
      },
      "inputs": [
        "{workspaceRoot}/scripts/wait-for-cms-before-build.mjs",
        "{workspaceRoot}/scripts/wait-for-graphql-server.mjs",
        "{workspaceRoot}/scripts/strapi-health.mjs",
        { "env": "ENABLE_PREVIEW" },
        { "env": "STRAPI_URL" },
        { "env": "STRAPI_API_TOKEN" }
      ]
    },
    "build": {
      "dependsOn": ["wait-for-cms", "codegen"],
      "inputs": [
        "default",
        "^default",
        "{projectRoot}/env.mjs",
        { "externalDependencies": ["next"] },
        { "dependentTasksOutputFiles": "**/*.d.ts", "transitive": true },
        { "env": "ENABLE_PREVIEW" },
        { "env": "STRAPI_URL" },
        { "env": "NEXT_PUBLIC_STRAPI_URL" },
        { "env": "NEXT_PUBLIC_STRAPI_INSPECTION_MODE" },
        { "env": "STRAPI_API_TOKEN" }
      ]
    },
    "codegen": {}
  }
}

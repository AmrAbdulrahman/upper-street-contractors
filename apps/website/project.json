{
  "name": "website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/website/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "dev": {
      "dependsOn": ["codegen"],
      "inputs": [
        "default",
        "^default",
        "{projectRoot}/env.mjs",
        { "externalDependencies": ["next"] },
        { "dependentTasksOutputFiles": "**/*.d.ts", "transitive": true },
        { "env": "NEXT_PUBLIC_APP_ENV" }
      ]
    },
    "build": {
      "dependsOn": ["codegen"],
      "inputs": [
        "default",
        "^default",
        "{projectRoot}/env.mjs",
        { "externalDependencies": ["next"] },
        { "dependentTasksOutputFiles": "**/*.d.ts", "transitive": true },
        { "env": "NEXT_PUBLIC_APP_ENV" }
      ]
    },
    "cms-schema": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{workspaceRoot}/scripts/generate-cms-schema.mjs",
        "{projectRoot}/zero-cms.config.mjs",
        "{projectRoot}/.zero-cms-store/types/**/*.json",
        "{workspaceRoot}/libs/zero-cms-core/src/**/*.ts",
        "{workspaceRoot}/libs/zero-cms-graphql/src/**/*.ts"
      ],
      "outputs": ["{projectRoot}/src/generated/schema.graphql"],
      "options": {
        "command": "node scripts/generate-cms-schema.mjs apps/website",
        "cwd": "{workspaceRoot}"
      }
    },
    "codegen": {
      "dependsOn": ["cms-schema"],
      "cache": true,
      "inputs": [
        "default",
        "{projectRoot}/codegen.ts",
        "{projectRoot}/src/**/*.graphql",
        "{projectRoot}/src/generated/schema.graphql"
      ],
      "outputs": ["{projectRoot}/src/generated/graphql.ts"],
      "executor": "nx:run-commands",
      "options": {
        "command": "graphql-codegen --config {projectRoot}/codegen.ts",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}

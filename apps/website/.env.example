# Strapi GraphQL endpoint (local dev default)
STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Full-access API token from Strapi admin: Settings → API Tokens
# Or mint one: cd apps/cms && node scripts/create-api-token.mjs
STRAPI_API_TOKEN=

# Set to true to fetch draft Strapi content and run Next.js in server mode
ENABLE_PREVIEW=false

# Always-on inspect overlays (otherwise use ?inspect=true when ENABLE_PREVIEW=true)
# NEXT_PUBLIC_STRAPI_INSPECTION_MODE=true

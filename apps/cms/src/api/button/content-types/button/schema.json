{
  "kind": "collectionType",
  "collectionName": "buttons",
  "info": {
    "singularName": "button",
    "pluralName": "buttons",
    "displayName": "button"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "label": {
      "type": "string"
    },
    "variant": {
      "type": "enumeration",
      "enum": ["contained", "outlined", "text"],
      "default": "contained"
    },
    "color": {
      "type": "enumeration",
      "enum": ["green", "dark_blue", "white", "black"],
      "default": "green"
    },
    "borderRadius": {
      "type": "integer"
    },
    "icon": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::icon.icon"
    },
    "iconPosition": {
      "type": "enumeration",
      "enum": ["start", "end"],
      "default": "start"
    },
    "action": {
      "type": "enumeration",
      "enum": ["whatsapp", "contact_form"]
    },
    "href": {
      "type": "text"
    }
  }
}

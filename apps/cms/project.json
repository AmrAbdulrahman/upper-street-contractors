{
  "name": "cms",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/cms/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "nx:noop"
    },
    "dev": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cms",
        "command": "npm run develop"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", "^default"],
      "outputs": [
        "{projectRoot}/build",
        "{projectRoot}/dist"
      ],
      "options": {
        "cwd": "apps/cms",
        "command": "npm run build"
      }
    },
    "start": {
      "continuous": true,
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "apps/cms",
        "command": "npm run start"
      }
    },
    "console": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cms",
        "command": "npm run console"
      }
    }
  }
}
